"""Auto-generated basic CLI wrapper for {{ app_name }}.app — do not edit manually.

This app does not provide a scripting definition (.sdef), so only macOS
standard commands are available.
"""

import json
import subprocess
import sys

import click


def _run_applescript(script: str) -> str:
    """Execute an AppleScript and return its stdout."""
    result = subprocess.run(
        ["osascript", "-e", script],
        capture_output=True,
        text=True,
        timeout=30,
    )
    if result.returncode != 0:
        stderr = result.stderr.strip()
        if "-1743" in stderr:
            click.echo(
                "Error: permission denied.\n"
                "Go to System Settings > Privacy & Security > Automation\n"
                "and allow this app to control {{ app_name }}.",
                err=True,
            )
            sys.exit(1)
        msg = stderr.split("execution error: ")[-1] if "execution error:" in stderr else stderr
        click.echo(f"Error: {msg}", err=True)
        sys.exit(1)
    return result.stdout.strip()


def _output(ctx: click.Context, data: str) -> None:
    if ctx.obj.get("json"):
        click.echo(json.dumps({"result": data}))
    else:
        click.echo(data)


def _print_summary() -> None:
    click.echo("clam-{{ app_id }} — {{ app_name }} 的命令行控制工具（基础模式）\n")
    click.echo("核心能力:")
    click.echo("  ⚡ 基础控制    前置窗口、退出应用、打开文件")
    click.echo("  📊 基本信息    应用名称、版本号、窗口状态")
    click.echo("")
    click.echo("  ⚠️  该应用未提供脚本化接口，仅支持 macOS 标准命令。")
    click.echo("")
    click.echo("快速上手:")
    click.echo("  $ clam-{{ app_id }} activate        前置窗口")
    click.echo("  $ clam-{{ app_id }} get-version      查看版本")
    click.echo("  $ clam-{{ app_id }} quit             退出应用")
    click.echo("")
    click.echo("查看完整 API:")
    click.echo("  $ clam-{{ app_id }} api")


class _ClamGroup(click.Group):
    def format_help(self, ctx, formatter):
        _print_summary()

    def invoke(self, ctx):
        if not ctx.protected_args and not ctx.invoked_subcommand:
            _print_summary()
            return
        return super().invoke(ctx)


@click.group(cls=_ClamGroup, invoke_without_command=True)
@click.option("--json", "use_json", is_flag=True, help="Output as JSON.")
