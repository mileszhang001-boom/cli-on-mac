"""Auto-generated CLI wrapper for {{ app_name }}.app — do not edit manually."""

import json
import subprocess
import sys

import click


def _run_applescript(script: str) -> str:
    """Execute an AppleScript and return its stdout."""
    result = subprocess.run(
        ["osascript", "-e", script],
        capture_output=True,
        text=True,
        timeout=30,
    )
    if result.returncode != 0:
        stderr = result.stderr.strip()
        if "-1743" in stderr:
            click.echo(
                "Error: permission denied.\n"
                "Go to System Settings > Privacy & Security > Automation\n"
                "and allow this app to control {{ app_name }}.",
                err=True,
            )
            sys.exit(1)
        if "-1728" in stderr:
            click.echo(
                "Error: object not available (e.g. no current track playing).",
                err=True,
            )
            sys.exit(1)
        if "-1708" in stderr:
            click.echo("Error: {{ app_name }} does not support this command.", err=True)
            sys.exit(1)
        if "-1700" in stderr:
            click.echo("Error: type conversion failed — value type mismatch.", err=True)
            sys.exit(1)
        if "-600" in stderr or "-10810" in stderr:
            click.echo("Error: {{ app_name }} is not running.", err=True)
            sys.exit(1)
        if "-1719" in stderr:
            click.echo("Error: invalid index — the specified item does not exist.", err=True)
            sys.exit(1)
        # Strip verbose AppleScript error prefix
        msg = stderr.split("execution error: ")[-1] if "execution error:" in stderr else stderr
        click.echo(f"Error: {msg}", err=True)
        sys.exit(1)
    return result.stdout.strip()


def _format_value(value, sdef_type: str) -> str:
    """Format a Python value for AppleScript."""
    if sdef_type in ("text", "Unicode text", "string"):
        escaped = str(value).replace('\\', '\\\\').replace('"', '\\"')
        return f'"{escaped}"'
    if sdef_type in ("integer", "real", "double integer", "number"):
        return str(value)
    if sdef_type == "boolean":
        return "true" if str(value).lower() in ("true", "1", "yes") else "false"
    if sdef_type in ("file", "alias"):
        escaped = str(value).replace('\\', '\\\\').replace('"', '\\"')
        return f'POSIX file "{escaped}"'
    if sdef_type == "enum":
        return str(value)
    # Default: quote as text (safer than bare string)
    escaped = str(value).replace('\\', '\\\\').replace('"', '\\"')
    return f'"{escaped}"'


def _output(ctx: click.Context, data: str) -> None:
    """Print output, optionally as JSON."""
    if ctx.obj.get("json"):
        click.echo(json.dumps({"result": data}))
    else:
        click.echo(data)


