    click.echo("属性 (get/set):")
{% for prop in app_properties %}
    click.echo("  get-{{ prop.cli_name.ljust(26) }} {{ prop.description_short }}{% if prop.access == 'rw' %}  [可写: set-{{ prop.cli_name }}]{% endif %}")
{% endfor %}
{% endif %}
{% for group in nested_groups %}
    click.echo("")
    click.echo("{{ group.as_name }} ({{ group.class_name }}) 属性:")
    click.echo("  get-{{ group.cli_name.ljust(26) }} 获取全部属性 (JSON)")
{% for prop in group.properties %}
    click.echo("  get-{{ group.cli_name }}-{{ prop.cli_name.ljust(26 - group.cli_name | length - 1) }} {{ prop.as_name }}{% if prop.access == 'rw' %}  [可写]{% endif %}")
{% endfor %}
{% endfor %}


# ── Action commands ──────────────────────────────────────────────────────────
{% for cmd in commands %}

@cli.command(name="{{ cmd.cli_name }}")
{% if cmd.specifier_default %}
@click.argument("target", required=False, default=None)
{% elif cmd.direct_param and cmd.direct_optional %}
@click.argument("item", required=False, default=None)
{% elif cmd.direct_param %}
@click.argument("item")
{% endif %}
{% for param in cmd.params %}
{% if param.is_flag %}
@click.option("--{{ param.cli_name }}", is_flag=True, default=False, help="{{ param.description }}")
{% elif param.choices %}
@click.option("--{{ param.cli_name }}", type=click.Choice({{ param.choices }}), default=None, help="{{ param.description }}")
{% else %}
@click.option("--{{ param.cli_name }}", default=None, help="{{ param.description }}")
{% endif %}
{% endfor %}
@click.pass_context
def {{ cmd.func_name }}(ctx{% if cmd.specifier_default %}, target{% elif cmd.direct_param %}, item{% endif %}{% for param in cmd.params %}, {{ param.func_name }}{% endfor %}) -> None:
    """{{ cmd.description }}"""
    parts = ["{{ cmd.name }}"]
{%- if cmd.specifier_default %}
    parts.append(target if target is not None else "{{ cmd.specifier_default }}")
{%- elif cmd.direct_param and cmd.direct_optional %}
    if item is not None:
        parts.append(_format_value(item, "{{ cmd.direct_type }}"))
{%- elif cmd.direct_param %}
    parts.append(_format_value(item, "{{ cmd.direct_type }}"))
{%- endif %}
{% for param in cmd.params %}
{% if param.is_flag %}
    if {{ param.func_name }}:
        parts.append("with {{ param.as_name }}")
{% else %}
    if {{ param.func_name }} is not None:
        parts.append("{{ param.as_name }}")
        parts.append(_format_value({{ param.func_name }}, "{{ param.sdef_type }}"))
{% endif %}
{% endfor %}
    script = f'tell application "{{ app_name }}" to {" ".join(parts)}'
    result = _run_applescript(script)
    if result:
        _output(ctx, result)
{% endfor %}

