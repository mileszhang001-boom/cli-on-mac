@cli.command(name="get-{{ group.cli_name }}")
@click.pass_context
def get_{{ group.func_name }}(ctx: click.Context) -> None:
    """Get all properties of {{ group.as_name }} as JSON."""
    script = (
        'tell application "{{ app_name }}"\n'
        '    set t to {{ group.as_name }}\n'
        '    set d to ASCII character 9\n'
        '    set output to ""\n'
{% for prop in group.properties[:max_compound_props] %}
        '    try\n'
        '        set output to output & "{{ prop.as_name }}" & d & ({{ prop.as_name }} of t as text) & linefeed\n'
        '    end try\n'
{% endfor %}
        '    return output\n'
        'end tell'
    )
    raw = _run_applescript(script)
    data = {}
    for line in raw.split("\n"):
        if "\t" in line:
            key, _, val = line.partition("\t")
            data[key] = val
    if ctx.obj.get("json"):
        click.echo(json.dumps(data, ensure_ascii=False, indent=2))
    else:
        for k, v in data.items():
            click.echo(f"  {k}: {v}")
