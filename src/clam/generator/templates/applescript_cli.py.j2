    click.echo("clam-{{ app_id }} — {{ app_name }} 的命令行控制工具\n")
    click.echo("核心能力:")
{% if commands %}
    click.echo("  ⚡ 执行操作    {{ commands | length }} 个命令{% if commands | length <= 8 %}：{{ commands | map(attribute='cli_name') | join('、') }}{% endif %}")
{% endif %}
{% if app_properties %}
{%- set rw_props = [] %}
{%- for p in app_properties %}{% if p.access == "rw" %}{% if rw_props.append(p) %}{% endif %}{% endif %}{% endfor %}
    click.echo("  📊 读写状态    {{ app_properties | length }} 个属性{% if rw_props %}（{{ rw_props | length }} 个可写）{% endif %}")
{% endif %}
{% for group in nested_groups %}
    click.echo("  🔍 {{ group.as_name }}    {{ group.properties | length }} 个属性可深层访问")
{% endfor %}
    click.echo("")
    click.echo("快速上手:")
{% if commands %}
    click.echo("  $ clam-{{ app_id }} {{ commands[0].cli_name }}{{ '                    ' + commands[0].description if commands[0].description else '' }}")
{% endif %}
{% if app_properties %}
    click.echo("  $ clam-{{ app_id }} get-{{ app_properties[0].cli_name }}{{ '           读取' + app_properties[0].description_short if app_properties[0].description_short else '' }}")
{% if app_properties[0].access == "rw" %}
    click.echo("  $ clam-{{ app_id }} set-{{ app_properties[0].cli_name }} <值>    设置{{ app_properties[0].description_short }}")
{% endif %}
