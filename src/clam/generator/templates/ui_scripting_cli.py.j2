"""Auto-generated UI-scripting CLI wrapper for {{ app_name }}.app — do not edit manually.

This app does not provide a scripting definition (.sdef). Commands are
implemented via macOS Accessibility / UI Scripting (System Events menu clicks).
Requires Accessibility permission for Terminal / your IDE.
"""

import json
import subprocess
import sys

import click


def _run_applescript(script: str) -> str:
    """Execute an AppleScript and return its stdout."""
    result = subprocess.run(
        ["osascript", "-e", script],
        capture_output=True,
        text=True,
        timeout=30,
    )
    if result.returncode != 0:
        stderr = result.stderr.strip()
        if "-1743" in stderr:
            click.echo(
                "Error: permission denied.\n"
                "Go to System Settings > Privacy & Security > Automation\n"
                "and allow this app to control {{ app_name }}.",
                err=True,
            )
            sys.exit(1)
        if "-25211" in stderr:
            click.echo(
                "Error: accessibility access denied.\n"
                "Go to System Settings > Privacy & Security > Accessibility\n"
                "and allow Terminal (or your IDE) to control your computer.",
                err=True,
            )
            sys.exit(1)
        if "-1708" in stderr:
            click.echo("Error: {{ app_name }} does not support this command.", err=True)
            sys.exit(1)
        if "-600" in stderr or "-10810" in stderr:
            click.echo("Error: {{ app_name }} is not running.", err=True)
            sys.exit(1)
        msg = stderr.split("execution error: ")[-1] if "execution error:" in stderr else stderr
        click.echo(f"Error: {msg}", err=True)
        sys.exit(1)
    return result.stdout.strip()


def _click_menu(menu_bar_item: str, menu_item: str, submenu_of: str | None = None) -> None:
    """Click a menu item via System Events UI Scripting."""
    _run_applescript(f'tell application "{{ app_name }}" to activate')
    if submenu_of:
        script = (
            'tell application "System Events"\n'
            f'    tell process "{{ process_name }}"\n'
            f'        click menu item "{menu_item}" of menu 1 of '
            f'menu item "{submenu_of}" of menu 1 of '
            f'menu bar item "{menu_bar_item}" of menu bar 1\n'
            '    end tell\n'
            'end tell'
        )
    else:
        script = (
            'tell application "System Events"\n'
            f'    tell process "{{ process_name }}"\n'
            f'        click menu item "{menu_item}" of menu 1 of '
            f'menu bar item "{menu_bar_item}" of menu bar 1\n'
            '    end tell\n'
            'end tell'
        )
    _run_applescript(script)


def _output(ctx: click.Context, data: str) -> None:
    if ctx.obj.get("json"):
        click.echo(json.dumps({"result": data}))
    else:
        click.echo(data)


def _print_summary() -> None:
    click.echo("{{ i18n.summary_ui }}\n")
    click.echo("{{ i18n.capabilities }}")
{% for group in menu_groups %}
    click.echo("  🎛  {{ group.name }}    {{ group.items | length }} {{ i18n.unit_ops }}{{ i18n.colon_sep }}{{ group.items | map(attribute='name') | join(i18n.join_sep) }}")
{% endfor %}
    click.echo("  ⚡ {{ i18n.basic_controls_ui }}")
    click.echo("  📊 {{ i18n.basic_info_ui }}")
    click.echo("")
    click.echo("  ⚠️  {{ i18n.no_sdef_ui }}")
    click.echo("  ⚠️  {{ i18n.accessibility_warning }}")
    click.echo("")
    click.echo("{{ i18n.quickstart }}")
{% if first_menu_cmd %}
    click.echo("  $ clam-{{ app_id }} {{ first_menu_cmd }}{{ ' ' * (20 - first_menu_cmd | length) }}{{ first_menu_desc }}")
{% endif %}
    click.echo("  $ clam-{{ app_id }} activate            {{ i18n.activate_doc }}")
    click.echo("")
    click.echo("{{ i18n.view_api_basic }}")
    click.echo("  $ clam-{{ app_id }} api")


class _ClamGroup(click.Group):
    def format_help(self, ctx, formatter):
        _print_summary()

    def invoke(self, ctx):
        if not ctx.protected_args and not ctx.invoked_subcommand:
            _print_summary()
            return
        return super().invoke(ctx)


@click.group(cls=_ClamGroup, invoke_without_command=True)
@click.option("--json", "use_json", is_flag=True, help="Output as JSON.")
@click.pass_context
def cli(ctx: click.Context, use_json: bool) -> None:
    """Control {{ app_name }}.app from the command line (UI scripting mode)."""
    ctx.ensure_object(dict)
    ctx.obj["json"] = use_json


@cli.command(name="api")
def api_cmd() -> None:
    """{{ i18n.api_docstring_basic }}"""
{% for group in menu_groups %}
    click.echo("{{ group.name }}:")
{% for item in group.items %}
{% if item.submenu_of %}
    click.echo("  {{ item.cli_name.ljust(30) }} {{ item.submenu_of }} → {{ item.name }}")
{% else %}
    click.echo("  {{ item.cli_name.ljust(30) }} {{ item.name }}")
{% endif %}
{% endfor %}
    click.echo("")
{% endfor %}
    click.echo("{{ i18n.basic_controls_label }}")
    click.echo("  activate                        {{ i18n.activate_api }}")
    click.echo("  quit-app                        {{ i18n.quit_api }}")
    click.echo("  open-file {{ i18n.path_arg }}                {{ i18n.open_api }}")
    click.echo("")
    click.echo("{{ i18n.basic_info_label }}")
    click.echo("  get-name                        {{ i18n.name_api }}")
    click.echo("  get-version                     {{ i18n.version_api }}")
    click.echo("  get-frontmost                   {{ i18n.frontmost_api }}")


# ── Menu-driven commands ────────────────────────────────────────────────────
{% for group in menu_groups %}
{% for item in group.items %}

@cli.command(name="{{ item.cli_name }}")
@click.pass_context
def {{ item.func_name }}(ctx: click.Context) -> None:
{% if item.submenu_of %}
    """{{ item.submenu_of }} → {{ item.name }}"""
    _click_menu("{{ group.name }}", "{{ item.name }}", submenu_of="{{ item.submenu_of }}")
{% else %}
    """{{ item.name }}"""
    _click_menu("{{ group.name }}", "{{ item.name }}")
{% endif %}
    click.echo("{{ item.name }} ✓")
{% endfor %}
{% endfor %}


