@cli.command(name="activate")
@click.pass_context
def activate_cmd(ctx: click.Context) -> None:
    """前置窗口"""
    _run_applescript('tell application "{{ app_name }}" to activate')
    click.echo("{{ app_name }} 已前置")


@cli.command(name="quit-app")
@click.pass_context
def quit_cmd(ctx: click.Context) -> None:
    """退出应用"""
    _run_applescript('tell application "{{ app_name }}" to quit')
    click.echo("{{ app_name }} 已退出")


@cli.command(name="open-file")
@click.argument("filepath")
@click.pass_context
def open_file_cmd(ctx: click.Context, filepath: str) -> None:
    """用该应用打开文件"""
    script = f'tell application "{{ app_name }}" to open POSIX file "{filepath}"'
    _run_applescript(script)
    click.echo(f"已用 {{ app_name }} 打开 {filepath}")


@cli.command(name="get-name")
@click.pass_context
def get_name_cmd(ctx: click.Context) -> None:
    """获取应用名称"""
    result = _run_applescript('tell application "{{ app_name }}" to get name')
    _output(ctx, result)


@cli.command(name="get-version")
@click.pass_context
def get_version_cmd(ctx: click.Context) -> None:
    """获取版本号"""
    result = _run_applescript('tell application "{{ app_name }}" to get version')
    _output(ctx, result)


@cli.command(name="get-frontmost")
@click.pass_context
def get_frontmost_cmd(ctx: click.Context) -> None:
    """是否为当前活跃窗口"""
    result = _run_applescript('tell application "{{ app_name }}" to get frontmost')
    _output(ctx, result)


if __name__ == "__main__":
    cli()
