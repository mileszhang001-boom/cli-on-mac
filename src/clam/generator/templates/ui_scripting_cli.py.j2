@cli.command(name="activate")
@click.pass_context
def activate_cmd(ctx: click.Context) -> None:
    """{{ i18n.activate_doc }}"""
    _run_applescript('tell application "{{ app_name }}" to activate')
    click.echo("{{ i18n.activated_msg }}")


